# 环境变量配置示例
# 复制此文件为 .env 并根据实际环境修改

# ========== 数据库配置 ==========
# PostgreSQL 连接 URL
# 格式: postgres://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgres://app:secret@localhost:5432/app_db

# SQLite 连接 URL（开发/测试环境使用）
SQLITE_URL=sqlite:./data/app.db

# ========== Redis 配置 ==========
# Redis 连接 URL
REDIS_URL=redis://localhost:6379

# ========== 服务配置 ==========
# 服务器监听地址（0.0.0.0 表示允许外部访问）
SERVER_HOST=0.0.0.0
# 服务器监听端口
SERVER_PORT=3000

# ========== 日志配置 ==========
# Rust 日志级别配置
# 格式: crate名=级别,另一crate=级别
RUST_LOG=backend=debug,tower_http=debug

# ========== 环境配置 ==========
# 运行环境: development / staging / production
ENVIRONMENT=development
