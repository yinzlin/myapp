# EditorConfig 代码编辑器配置
# 参考文档: https://editorconfig.org/

# 根目录配置
root = true

# 所有文件通用配置
[*]
# 字符编码
charset = utf-8
# 结尾换行符：LF（Unix 风格）
end_of_line = lf
# 结尾自动添加空白行
insert_final_newline = true
# 结尾去除空白
trim_trailing_whitespace = true
# 缩进样式：空格
indent_style = space

# Rust 源文件
[*.rs]
# 缩进大小：4 个空格
indent_size = 4
# 最大行宽度：100 字符
max_line_length = 100

# TOML 配置文件
[*.toml]
# 缩进大小：2 个空格
indent_size = 2

# YAML 配置文件
[*.{yaml,yml}]
# 缩进大小：2 个空格
indent_size = 2

# JSON 文件
[*.json]
# 缩进大小：2 个空格
indent_size = 2

# Markdown 文件
[*.md]
# 结尾不去除空白（避免破坏 Markdown 语法）
trim_trailing_whitespace = false
# 最大行宽度：80 字符
max_line_length = 80

# Shell 脚本
[*.sh]
# 结尾换行符：LF
end_of_line = lf

# PowerShell 脚本
[*.ps1]
# 结尾换行符：CRLF（Windows 兼容）
end_of_line = crlf
