# Git 忽略配置文件
# 参考文档: https://git-scm.com/docs/gitignore

# ========== Rust 构建产物 ==========
# Cargo 构建目标目录
/target
# Rust 备份文件
**/*.rs.bk
# Cargo 依赖锁定文件（通常不提交）
Cargo.lock

# ========== 环境变量文件 ==========
# 本地环境变量
.env
.env.local
.env.*.local

# ========== 数据库文件 ==========
# SQLite 数据库文件
*.db
*.db-shm
*.db-wal
# 数据库数据目录
data/

# ========== IDE 配置 ==========
# VSCode 配置目录
.vscode/
# IntelliJ IDEA 配置目录
.idea/
# Vim 交换文件
*.swp
*.swo
*~

# ========== 系统文件 ==========
# macOS 系统文件
.DS_Store
# Windows 缩略图缓存
Thumbs.db

# ========== 日志文件 ==========
# 日志文件
*.log
# 日志目录
logs/

# ========== 前端构建产物 ==========
# 前端构建输出目录
dist/
# Node.js 依赖目录
node_modules/
